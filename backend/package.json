    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "express": "^5.1.0",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
